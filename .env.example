DJANGO_SETTINGS_MODULE=config.settings.develop
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3
# Gmail SMTP: увімкніть 2FA → Security → App Passwords → згенеруйте пароль
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=your@gmail.com
ADMIN_EMAIL=куди_приходять_заявки@gmail.com

# Google Tag Manager (залиш порожнім, якщо не потрібно)
GTM_ID=
